ENVIRONMENT=development
SECRET_KEY=replace-with-at-least-32-random-characters
DATABASE_URL=postgresql+asyncpg://earth:earth@postgres:5432/earth_monitor
CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]
BOOTSTRAP_LOCAL_WORKSPACE=true
ALLOW_PUBLIC_REGISTRATION=true
LOCAL_USER_EMAIL=analyst@terralens.app
LOCAL_USER_PASSWORD=LocalAccess123!
STAC_API_URL=https://planetarycomputer.microsoft.com/api/stac/v1
STAC_COLLECTION=sentinel-2-l2a
CELESTRAK_GP_URL=https://celestrak.org/NORAD/elements/gp.php
ORBITAL_GROUPS=["resource","weather","planet"]
ORBITAL_CACHE_SECONDS=7200
PLANET_SATELLITE_LIMIT=24
USGS_EARTHQUAKE_FEED_URL=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_day.geojson
HAZARD_CACHE_SECONDS=60
SWPC_BASE_URL=https://services.swpc.noaa.gov
CAD_API_URL=https://ssd-api.jpl.nasa.gov/cad.api
EONET_EVENTS_URL=https://eonet.gsfc.nasa.gov/api/v3/events
SPACE_WEATHER_CACHE_SECONDS=60
NEO_CACHE_SECONDS=3600
EARTH_EVENTS_CACHE_SECONDS=300
NEO_LOOKAHEAD_DAYS=7
NEO_MAX_DISTANCE_AU=0.05
EARTH_EVENTS_LOOKBACK_DAYS=14
SOLAR_STREAM_INTERVAL_SECONDS=30
PROVIDER_MAX_ATTEMPTS=3
PROVIDER_BACKOFF_SECONDS=0.25
PROVIDER_MAX_ITEMS=200
MONITORING_LOOKBACK_DAYS=30
MAX_REQUEST_BODY_BYTES=1048576
DETECTOR_MAX_WINDOW_PIXELS=4000000
DETECTOR_CLOUD_COVER_MAX=20.0
DETECTOR_MIN_DAYS_BETWEEN_PAIR=3
DETECTOR_NDVI_THRESHOLD=0.15
DETECTOR_MIN_CHANGE_FRACTION=0.005
MONITORING_SCHEDULER_ENABLED=true
SCHEDULER_POLL_INTERVAL_SECONDS=900
SCHEDULER_STARTUP_DELAY_SECONDS=60
SCHEDULER_MAX_CONCURRENT_RUNS=3
GLOBAL_STREAM_INTERVAL_SECONDS=60
VITE_API_URL=http://localhost:8000/api/v1
VITE_CESIUM_ION_TOKEN=
# Local appliance mode: auto-provisioned operator, no login required.
# Only enable on a trusted network (e.g. a LAN-only Proxmox deployment).
LOCAL_MODE=true
LOCAL_OPERATOR_EMAIL=operator@terralens.app
# Adaptive learning: archive live space-weather readings, learn baselines,
# and self-score statistical forecasts.
LEARNING_ENABLED=true
LEARNING_INTERVAL_SECONDS=300
LEARNING_MIN_BASELINE_SAMPLES=288
LEARNING_BASELINE_WINDOW_DAYS=60
LEARNING_RETENTION_DAYS=365
# Autonomous capture of live space imagery (SDO/SOHO/SUVI/EPIC).
IMAGERY_ENABLED=true
IMAGERY_DIR=/data/imagery
IMAGERY_INTERVAL_SECONDS=900
IMAGERY_MAX_CAPTURES_PER_SOURCE=400
# Host interface Compose publishes on: keep 127.0.0.1 for a single machine,
# set 0.0.0.0 on a LAN appliance (Proxmox VM) so other devices can reach it.
BIND_HOST=127.0.0.1
